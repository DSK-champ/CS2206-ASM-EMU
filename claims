  02_factorial.asm  —  iterative factorial  (n=6)
  Instructions executed: 292

    [ALGORITHM]                        [STACK]
    result = 1                         adj -5
    i = 2                                SP+0  result
    while i <= n:                        SP+1  i
      product = 0                        SP+2  n
