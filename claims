  03_fibonacci.asm  —  iterative Fibonacci  (n=10)
  Instructions executed: 227

    [ALGORITHM]                        [STACK]
    a = 0,  b = 1                      adj -4
    i = 2                                SP+0  a
    while i <= n:                        SP+1  b
      next = a + b                       SP+2  i
      a = b                              SP+3  n
      b = next
      i++
    return b


  04_palindrome.asm  —  palindrome checker
  Instructions executed:  n=121->515   n=1221->1875   n=12021->13979   n=120021->134101

    [ALGORITHM]                        [STACK]
    rev = 0,  temp = n                 adj -7
    while temp > 0:                      SP+0  original
      quotient = 0                       SP+1  rev
      while temp >= 10:                  SP+2  temp
        temp -= 10                       SP+3  digit
        quotient++                       SP+4  quotient
      digit = temp                       SP+5  shifted
      temp = quotient                    SP+6  count
      shifted = 0,  count = 10
      while count > 0:
        shifted += rev
        count--
      rev = shifted + digit
    return (rev == original) ? 1 : 0


